# -------------------------------
# Azure subscription / location
# -------------------------------
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_LOCATION=westeurope
RESOURCE_GROUP=rg-stopsales-dev
PREFIX=stopsalesdev

# -------------------------------
# Core resources
# -------------------------------
STORAGE_ACCOUNT_NAME=stopsalesdevsa
BLOB_CONTAINER_RAW_EMAILS=raw-emails
BLOB_CONTAINER_ATTACHMENTS=attachments

SERVICEBUS_NAMESPACE=stopsalesdevsb
SERVICEBUS_QUEUE=stopsales
SERVICEBUS_MAX_DELIVERY_COUNT=10

APP_INSIGHTS_NAME=stopsalesdev-ai
KEYVAULT_NAME=stopsalesdev-kv

FUNCTIONAPP_NAME=stopsalesdev-func
FUNCTIONAPP_PLAN=stopsalesdev-plan

REVIEWAPP_NAME=stopsalesdev-review
REVIEWAPP_PLAN=stopsalesdev-review-plan

SQL_SERVER_NAME=stopsalesdev-sql
SQL_DATABASE_NAME=stopsales
SQL_ADMIN_USER=sqladminuser
# NO metas el password en Git: usa Key Vault
SQL_ADMIN_PASSWORD=

# -------------------------------
# Foundry (AI Services) + Project
# -------------------------------
FOUNDRY_RESOURCE_NAME=stopsalesdev-foundry
FOUNDRY_PROJECT_NAME=stopsales-project

# Se rellena tras crear el proyecto (scripts/deploy/20...)
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# Agentes (si los creas en Foundry)
AGENT_CLASSIFIER_NAME=StopSales-Classifier
AGENT_BODY_EXTRACTOR_NAME=StopSales-BodyExtractor
AGENT_PDF_EXTRACTOR_NAME=StopSales-PDFExtractor
AGENT_VISUAL_EXTRACTOR_NAME=StopSales-VisualExtractor
AGENT_NORMALIZER_NAME=StopSales-Normalizer

# -------------------------------
# Integración destino
# -------------------------------
DESTINATION_API_URL=https://example.com/api/stopsales
DESTINATION_API_KEY=

# -------------------------------
# Umbrales / flags
# -------------------------------
CONFIDENCE_THRESHOLD=0.85

# (Opcional) trazas genAI (preview)
AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING=true
AZURE_TRACING_GEN_AI_ENABLE_TRACE_CONTEXT_PROPAGATION=true
# Connection string para trigger de Azure Functions (puedes guardar en Key Vault)
SERVICEBUS_CONNECTION=


