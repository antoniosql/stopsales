{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "hotel_raw": {
            "type": "string"
          },
          "room_raw": {
            "type": [
              "string",
              "null"
            ]
          },
          "market_raw": {
            "type": [
              "string",
              "null"
            ]
          },
          "operator_raw": {
            "type": [
              "string",
              "null"
            ]
          },
          "action": {
            "type": "string",
            "enum": [
              "STOP",
              "OPEN"
            ]
          },
          "start_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "end_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          },
          "extraction_confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "hotel_raw",
          "action",
          "start_date",
          "end_date"
        ]
      }
    }
  },
  "required": [
    "events"
  ]
}